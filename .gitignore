*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your .python-version.
#   For an app, you may want to ignore it.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used with a windows machine, locks could be different.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be either shared or ignored.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be either shared or ignored.
#   pdm.lock

# venv
.venv/
venv/
ENV/
env/
pythonenv/

# IDEs
.vscode/
.idea/

# Local configuration
.env
.env.local
.env.development
.env.production
.env.staging
